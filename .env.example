# SimNow 环境配置（复制为 .env 后替换为实际值）
CTP_CONFIG_PATH=configs/sim/ctp.yaml

# 无人值守仿真交易默认使用交易时段 300xx 前置。
# 如果仅做 7x24 API 测试，可改为 false 并使用 400xx 前置，但不要用于自动交易脚本。
CTP_SIM_IS_PRODUCTION_MODE=true

# core_engine 使用真实 CTP API 时设为 true，并使用 -DQUANT_HFT_ENABLE_CTP_REAL_API=ON 构建。
# simnow_probe 会在运行时强制启用真实 API。
CTP_SIM_ENABLE_REAL_API=true

# SimNow 账号（必填，替换为实际值）
CTP_SIM_BROKER_ID=9999
CTP_SIM_USER_ID=your_user_id
CTP_SIM_INVESTOR_ID=your_investor_id
CTP_SIM_PASSWORD=your_password
CTP_SIM_AUTH_CODE=0000000000000000   # 默认认证码（16个0）
CTP_SIM_APP_ID=simnow_client_test     # 默认APPID

# SimNow 前置地址（第一套环境，三组前置均可使用，任选一组）
# 第一组: Trade Front: tcp://182.254.243.31:30001, Market Front: tcp://182.254.243.31:30011
# 第二组: Trade Front: tcp://182.254.243.31:30002, Market Front: tcp://182.254.243.31:30012
# 第三组: Trade Front: tcp://182.254.243.31:30003, Market Front: tcp://182.254.243.31:30013
# 第二套环境（7x24测试，需注册后第三个交易日可用，仅用于API测试）：
#   Trade Front: tcp://182.254.243.31:40001, Market Front: tcp://182.254.243.31:40011
CTP_SIM_MARKET_FRONT=tcp://182.254.243.31:30011
CTP_SIM_TRADER_FRONT=tcp://182.254.243.31:30001

# simnow_probe 默认订阅标的，可按需要替换。
CTP_SIM_INSTRUMENT=SHFE.ag2406

# 可选运行时配置（默认值见注释）
QUANT_HFT_REDIS_HOST=127.0.0.1
QUANT_HFT_REDIS_PORT=6379

# 无人值守仿真交易 supervisor 配置。
SIMNOW_TRADING_WINDOWS=night=20:55-02:35,day_am=08:55-11:35,day_pm=13:25-15:20
SIMNOW_EOD_TIME=15:25
SIMNOW_EOD_EXECUTE=1
SIMNOW_CHECK_INTERVAL_SECONDS=30
SIMNOW_MAX_RESTARTS_PER_WINDOW=5
SIMNOW_RESTART_DELAY_SECONDS=15
SIMNOW_MIN_FREE_MB=2048
SIMNOW_LOG_MAX_BYTES=104857600
SIMNOW_LOG_RETENTION_DAYS=14
SIMNOW_HEALTH_GRACE_SECONDS=180
SIMNOW_TICK_STALE_SECONDS=180
SIMNOW_BAR_STALE_SECONDS=240
SIMNOW_FILL_STALE_SECONDS=900
SIMNOW_REQUIRE_FILL_HEARTBEAT=0
SIMNOW_INSTRUMENT_TIMEOUT_SECONDS=45

# 可选交易日历：每行一个 YYYYMMDD 或 YYYY-MM-DD；留空时按工作日近似判断。
SIMNOW_TRADING_DAYS_FILE=

# 可选告警方式。Webhook 兼容企业微信文本 webhook 结构；也可用本地 mail 或自定义命令。
SIMNOW_ALERT_WEBHOOK_URL=
SIMNOW_ALERT_EMAIL_TO=
SIMNOW_ALERT_COMMAND=

# 可选日终自定义分析命令；执行时会注入 TRADING_DAY、SIMNOW_EOD_DIR、RUN_ROOT。
SIMNOW_ANALYSIS_COMMAND=
